# =============================================================================
# QR Service — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed.
# When using docker-compose, most defaults work out-of-the-box.
# =============================================================================

# --- Database ----------------------------------------------------------------
# PostgreSQL connection string.
# With docker-compose, the bundled db service is used automatically.
DATABASE_URL=postgres://qruser:qrpass@db:5432/qrservice?sslmode=disable

# Optional: Override the compose-provided database credentials
# POSTGRES_USER=qruser
# POSTGRES_PASSWORD=qrpass
# POSTGRES_DB=qrservice

# --- Server ------------------------------------------------------------------
# Port the service listens on inside the container (usually 8080)
PORT=8080

# Path where generated QR image files are stored
STORAGE_DIR=/app/storage/qrcodes

# Path to SQL migration files (auto-applied on startup)
MIGRATIONS_DIR=./migrations

# --- Security ----------------------------------------------------------------
# Master admin key for /v1/admin/* API key management endpoints.
# Leave empty to disable admin authentication (not recommended for production).
ADMIN_KEY=

# CORS allowed origins, comma-separated. Use * for any origin.
CORS_ORIGINS=*

# Rate limiting: max requests per IP within the expiration window.
RATE_LIMIT_MAX=30
RATE_LIMIT_EXPIRATION=60s

# --- Database Pool ----------------------------------------------------------
# Maximum number of PostgreSQL connections in the pool.
DB_MAX_CONNS=20
